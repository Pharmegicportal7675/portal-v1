# Hostinger MySQL (required)
DATABASE_URL=mysql://USER:PASSWORD@HOST:3306/DATABASE

# App (required for production)
NEXT_PUBLIC_APP_URL=https://portal.pharmegichealthcare.com

# JWT sessions (recommended in production)
AUTH_SECRET=generate-a-long-random-string

# SMTP — optional; primary config is Admin → Settings (admin_settings in MySQL)
# SMTP_HOST=mail.smtp2go.com
# SMTP_PORT=587
# SMTP_USER=your-smtp2go-user
# SMTP_PASS=your-smtp2go-password
# SMTP_FROM=Pharmegic Healthcare <noreply@pharmegichealthcare.com>
