{
  "name": "portal-v1",
  "version": "0.1.0",
  "private": true,
  "main": "server.js",
  "engines": {
    "node": ">=20.x"
  },
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build && node scripts/postbuild-standalone.mjs",
    "postinstall": "prisma generate",
    "start": "node server.js",
    "db:import": "prisma db execute --file prisma/database.mysql.sql --schema prisma/schema.prisma",
    "db:migrate:tcc-valid-until": "prisma db execute --file prisma/migrations/add-tcc-valid-until-date.sql --schema prisma/schema.prisma",
    "db:migrate:tcc-schema": "prisma db execute --file prisma/migrations/tcc-application-schema.sql --schema prisma/schema.prisma",
    "db:ensure-tcc-schema": "node scripts/ensure-tcc-schema.mjs",
    "lint": "eslint",
    "import:clients": "node scripts/import-clients-from-excel.js",
    "import:clients:dry": "node scripts/import-clients-from-excel.js --dry-run",
    "prepare:eu-reach": "node scripts/prepare-eu-reach-template.mjs && node scripts/generate-eu-reach-preview-pdf.mjs",
    "setup:pdf": "bash scripts/setup-pdf-converter.sh",
    "setup:live-pdf": "bash scripts/setup-live-pdf.sh",
    "deploy:live": "bash scripts/deploy-live.sh",
    "cleanup:tcc-docx": "npx tsx scripts/cleanup-tcc-docx-storage.ts",
    "cleanup:tcc-docx:dry": "npx tsx scripts/cleanup-tcc-docx-storage.ts --dry-run"
  },
  "dependencies": {
    "@prisma/adapter-mariadb": "^7.8.0",
    "@prisma/client": "^6.19.3",
    "@sparticuz/chromium-min": "^131.0.1",
    "@types/bcryptjs": "^2.4.6",
    "apexcharts": "^5.13.0",
    "bcryptjs": "^3.0.3",
    "clsx": "^2.1.1",
    "docx-preview": "^0.3.7",
    "docxtemplater": "^3.68.7",
    "dotenv": "^17.4.2",
    "html2canvas": "^1.4.1",
    "jose": "^6.2.3",
    "jspdf": "^4.2.1",
    "lucide-react": "^1.16.0",
    "mariadb": "^3.5.3",
    "next": "16.2.6",
    "nodemailer": "^8.0.7",
    "pizzip": "^3.2.0",
    "prisma": "^6.19.3",
    "puppeteer-core": "^23.11.1",
    "react": "19.2.4",
    "react-apexcharts": "^2.1.0",
    "react-dom": "19.2.4",
    "recharts": "^3.8.1",
    "tailwind-merge": "^3.6.0",
    "xlsx": "^0.18.5",
    "zod": "^4.4.3",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
